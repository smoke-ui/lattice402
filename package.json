{
  "name": "signal402",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c magenta,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx watch src/server/index.ts",
    "start:api": "tsx src/server/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "lint": "oxlint src",
    "check": "npm test && npm run typecheck && npm run lint && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@x402/avm": "^2.19.0",
    "@x402/core": "^2.19.0",
    "@x402/extensions": "^2.19.0",
    "@x402/hono": "^2.19.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.31",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
